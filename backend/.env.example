# Copy this file to .env and adjust values for your environment.

ENV=development
SECRET_KEY=change-this-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# SQLite for local/demo. For production use Postgres, e.g.:
# DATABASE_URL=postgresql://visionguard:visionguard@db:5432/visionguard
DATABASE_URL=sqlite:///./visionguard.db

CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# "demo" = pretrained ImageNet backbone + untrained head (functional demo)
# "production" = loads the fine-tuned checkpoint from MODEL_CHECKPOINT_PATH
MODEL_MODE=production
MODEL_CHECKPOINT_PATH=app/ml/weights/best_model.pth
MODEL_IMG_SIZE=380

UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
